# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment for docker compose.
#
#   On the server:  cp .env.production.example .env   (then fill every CHANGE_ME)
#
# Never commit the filled-in file — it holds secrets. The backend REFUSES to boot
# if any secret below is left at a dev default (see backend/app/config.py).
# ─────────────────────────────────────────────────────────────────────────────

# ── App mode ──
APP_ENV=production
SEED_DEMO_DATA=false          # no demo districts/users/tutorials; real data only

# ── Host binding & ports ──
# Keep on localhost: the host-level nginx (TLS) is the ONLY public entrypoint.
BIND_ADDR=127.0.0.1
FRONTEND_PORT=8080
BACKEND_PORT=8000

# ── Postgres ──
POSTGRES_USER=nurturehub
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password   # use a long value; e.g. `openssl rand -hex 24`
POSTGRES_DB=nurturehub

# ── Secrets (REQUIRED — boot fails without real values) ──
# Generate on the server:  openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Public origin / CORS ──
# The https domain the host nginx serves. (With the same-origin proxy, CORS only
# applies to cross-origin API calls, but set it correctly anyway.)
CORS_ORIGINS=https://nurturehub.example.org

# ── Email (OTP) — REQUIRED in production ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME@yourdomain.org
SMTP_PASSWORD=CHANGE_ME_smtp_app_password
SMTP_FROM=NurtureHUB <noreply@yourdomain.org>

# ── Google OAuth (optional; blank => mock login disabled path uses email/OTP) ──
GOOGLE_CLIENT_ID=

# ── Frontend build-time API/WS base ──
# Leave BLANK: the browser uses the same origin, and the frontend nginx proxies
# /api and /ws to the backend. (These are baked at image build — rebuild if changed.)
VITE_API_URL=
VITE_WS_URL=
