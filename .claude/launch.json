{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "venv-win/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8010"],
      "cwd": "backend",
      "port": 8010,
      "autoPort": false
    }
  ]
}
