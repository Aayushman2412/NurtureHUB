# ─────────────────────────────────────────────────────────────────────────────
# NurtureHUB — HOST-level nginx (managed by ops).
#
# Terminates TLS and forwards ALL traffic to the frontend container, which serves
# the SPA and internally proxies /api and /ws to the backend. So this host config
# only needs one upstream + WebSocket support — it doesn't need to know about the
# backend service at all.
#
# Assumes the compose stack runs on the same host with the frontend published on
# 127.0.0.1:8080  (i.e. BIND_ADDR=127.0.0.1, FRONTEND_PORT=8080 in .env).
#
# Replace nurturehub.example.org with the real domain and point the certs at your
# TLS files (e.g. Let's Encrypt / certbot).
# ─────────────────────────────────────────────────────────────────────────────

# Required once at the http{} scope (put in nginx.conf or an /etc/nginx/conf.d
# snippet) so WebSocket connections upgrade correctly:
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# HTTP -> HTTPS redirect (+ ACME challenge for cert issuance/renewal)
server {
    listen 80;
    listen [::]:80;
    server_name nurturehub.example.org;

    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name nurturehub.example.org;

    ssl_certificate     /etc/letsencrypt/live/nurturehub.example.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nurturehub.example.org/privkey.pem;

    # Match the app's upload limit (see frontend/nginx.conf + backend).
    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:8080;      # the frontend container

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;   # tells the app it's https

        # WebSocket upgrade (covers /ws/* used by live test monitoring)
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
    }
}
