# Choose database:
# 1. SQLite (Default, requires zero setup, runs instantly):
DATABASE_URL=sqlite:///./nurturehub.db

# 2. PostgreSQL (Optional, if you have PostgreSQL installed):
# DATABASE_URL=postgresql://postgres:password@localhost/NurtureHub

# Security key
JWT_SECRET_KEY=supersecretkeyfornurturehubdevelopment12345

# Optional SMTP setup for email OTPs
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
