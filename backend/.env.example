# ── NurtureHUB backend configuration ──────────────────────────────
# Copy to `.env` and fill in. `.env` is git-ignored — never commit real secrets.

# Environment: "development" or "production".
# In production the app refuses to boot if JWT_SECRET_KEY / DATABASE_URL are the
# dev defaults or SMTP is unconfigured.
APP_ENV=development

# Database
# SQLite (zero setup):        sqlite:///./nurturehub.db
# PostgreSQL:                 postgresql://postgres:password@localhost/NurtureHub
DATABASE_URL=sqlite:///./nurturehub.db

# JWT signing secret — generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=supersecretkeyfornurturehubdevelopment12345

# Google OAuth (optional). Leave blank to disable real Google verification.
GOOGLE_CLIENT_ID=

# ── Email / OTP delivery (SMTP) ────────────────────────────────────
# For a personal Gmail: enable 2-Step Verification, then create an App Password
# (Google Account → Security → App passwords → "Mail") and paste it as SMTP_PASSWORD.
# Note: free Gmail forces the visible sender to your own address and caps ~500/day.
# Leave SMTP_USER/SMTP_PASSWORD blank in development to print OTPs to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NurtureHUB <your-address@gmail.com>
SMTP_TIMEOUT=10

# OTP policy
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate limiting — "memory://" for a single process; use redis://host:6379 for multi-worker
RATE_LIMIT_STORAGE_URI=memory://

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
