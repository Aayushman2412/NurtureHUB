# Copy to `.env` (in the repo root) and adjust — docker compose reads it automatically.
#   cp .env.example .env

# ── Postgres ──
POSTGRES_USER=nurturehub
POSTGRES_PASSWORD=nurturehub
POSTGRES_DB=nurturehub

# ── App ──
# development = easy local run (dev defaults are allowed).
# production  = the backend REFUSES to boot unless JWT_SECRET_KEY, DATABASE_URL
#              and SMTP_USER/SMTP_PASSWORD are all real (see config.py).
APP_ENV=development

# Seed demo districts/users/tutorials/tests. Set false for a clean/production DB.
SEED_DEMO_DATA=true

# Strong random secret — REQUIRED when APP_ENV=production. Generate with:
#   openssl rand -hex 32
JWT_SECRET_KEY=supersecretkeyfornurturehubdevelopment12345

# Allowed browser origin(s) for the API, comma-separated. With the nginx
# same-origin proxy this only matters if you point the SPA straight at the backend.
CORS_ORIGINS=http://localhost:8080

# Google OAuth (optional). Blank => the UI falls back to a mock Google login.
GOOGLE_CLIENT_ID=

# SMTP for OTP email — REQUIRED when APP_ENV=production.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NurtureHUB <noreply@nurturehub.org>

# ── Host binding & ports ──
# BIND_ADDR: which host address the published ports listen on.
#   127.0.0.1 = localhost only (recommended; required when a host-level nginx/TLS
#               proxy sits in front — it's the only public entrypoint).
#   0.0.0.0   = expose directly on the machine's network interfaces.
BIND_ADDR=127.0.0.1
FRONTEND_PORT=8080
BACKEND_PORT=8000

# ── Frontend build-time API/WS base ──
# Leave BLANK to use the nginx same-origin proxy (recommended). Set only if you
# serve the SPA and API on different origins.
VITE_API_URL=
VITE_WS_URL=
